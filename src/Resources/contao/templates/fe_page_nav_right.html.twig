{#
  RCT – fe_page_nav_right.html.twig
  Variante mit festem Layout (sidebar-right).
  Theme und Layout werden nicht aus localStorage geladen.
#}
{% extends "@!fe_page.html.twig" %}

{% block head %}
  {{ parent() }}
  <style>
    @media (max-width: 1024px) {
      #rct-right-toggle { display: flex !important; }
      #right { display: block !important; }
    }
  </style>
{% endblock %}

{% block head_init %}
{{ parent() }}
<script>
  (function() {
    document.documentElement.setAttribute('data-fixed', '1');
    document.documentElement.setAttribute('data-theme', 'sparta2');
    document.documentElement.setAttribute('data-layout', 'sidebar-right');
    if (window.innerWidth > 1024 && localStorage.getItem('rct-sidebar-state') === 'closed') {
      document.documentElement.classList.add('rct-sidebar-initial-closed');
    }
  })();
</script>
{% endblock %}

{% block left_sidebar_close %}
<button class="rct-sidebar-close-btn js-close-sidebar" aria-label="Menü schließen">
  <svg class="rct-icon-shove" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path class="arrow-1" d="M6 6L12 12L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    <path class="arrow-2" d="M12 6L18 12L12 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
</button>
{% endblock %}

{% block header_nav %}
<div class="rct-header-nav">
  <div class="header-controls">
    <button id="rct-right-toggle" class="header-icon-btn" title="Navigation öffnen">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    {{ include('@!_rct_ctrl_language.html.twig') }}
  </div>
</div>
{% endblock %}
