{#
  RCT – fe_page_classic.html.twig
  Layout-Variante "Classic":
   - Header oben optional (classic_header section, leer = keine Höhe)
   - Navbar: edge-to-edge BG, innen .rct-content-inner mit Logo links + Menü rechts
   - #left: nur Mobile-Drawer (Hamburger-Toggle aus rct_nav_toggle Modul)
   - Main: ohne content-inner; Fullwidth-Sections brechen aus dem Article aus
   - Bottom: fixed Footer mit hellem Look + Footer-Logo
#}
{% extends "@Contao/fe_page.html.twig" %}

{% block head_init %}
  {{ parent() }}
  <script>
    (function() {
      document.documentElement.setAttribute('data-fixed', '1');
      document.documentElement.setAttribute('data-layout', 'classic');
    })();
  </script>
{% endblock %}

{% block wrapper %}
<div id="wrapper" class="rct-classic">
    {# Optionaler Header-Slot oben (leer = collapsed via CSS) #}
    <header id="header" class="rct-classic-header" role="banner">
      {{ contao_section('classic_header') }}
    </header>

    {# Edge-to-edge Navbar (Logo links + Menü rechts) #}
    <nav id="navbar" class="rct-classic-navbar" role="navigation" aria-label="Hauptnavigation">
      <div class="rct-classic-navbar-inner">
        <div class="rct-classic-navbar-left">
          {{ contao_section('classic_navbar_left') }}
        </div>
        <div class="rct-classic-navbar-right">
          {{ contao_section('classic_navbar_right') }}
        </div>
      </div>
    </nav>

    {# Mobile-Drawer #left — auf Desktop versteckt, auf Mobile via
       rct_nav_toggle (Hamburger im classic_navbar_right) togglebar #}
    <aside id="left" aria-label="Hauptnavigation">
      <button class="rct-sidebar-close-btn js-close-sidebar" aria-label="Menü schließen">
        <svg class="rct-icon-shove" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path class="arrow-1" d="M18 6L12 12L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          <path class="arrow-2" d="M12 6L6 12L12 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
      <div class="inside sitenavigation">{{ left|raw }}</div>
    </aside>

    {# Main ohne content-inner — Articles übernehmen die Zentrierung,
       Fullwidth-Sections brechen automatisch aus dem Article aus #}
    <main id="main" role="main">
      {{ main|raw }}

      <footer id="footer" role="contentinfo">
        {{ footer|raw }}
      </footer>
    </main>

    {# Bottom – gleiche Drei-Spalten-Struktur wie fe_page.html.twig,
       Klasse rct-classic-bottom triggert hellen Look #}
    <div id="bottom" class="rct-classic-bottom" role="contentinfo">
      <div class="inside">
        {{ contao_section('bottom_left') }}
        {{ contao_section('bottom_content') }}
        {{ contao_section('bottom_right') }}
      </div>
    </div>

</div>{# /#wrapper #}
{% endblock %}
