{#
  RCT – Rallos Contao Toolbox
  Template: fe_page.html.twig
  Contao: 5.7+
#}
{% extends "@Contao/fe_page.html.twig" %}

{% block head %}
  {% block head_init %}
  {# FOUC-Guard: sofort, inline, kein defer — muss vor CSS laufen #}
  <script>
    (function() {
      if (window.innerWidth > 1024 && localStorage.getItem('rct-sidebar-state') === 'closed') {
        document.documentElement.classList.add('rct-sidebar-initial-closed');
      }
      var t = localStorage.getItem('user-theme');
      if (t && t !== 'default') {
        document.documentElement.setAttribute('data-theme', t);
      }
      var l = localStorage.getItem('rct-layout');
      if (window.innerWidth > 1024
          && l !== 'topnav'
          && localStorage.getItem('rct-sidebar-right-state') === 'open') {
        document.documentElement.classList.add('rct-right-initial-open');
      }
      if (l && l !== 'sidebar') {
        document.documentElement.setAttribute('data-layout', l);
      }
    })();
  </script>
  {% endblock %}
  {{ parent() }}
  <link rel="icon" type="image/svg+xml" href="/bundles/rct/favicon.svg">
  <meta name="theme-color" content="#4a6700">
{% endblock %}

{% block body %}
  {% block wrapper %}
  <div id="wrapper">
      <canvas id="rct-sky-canvas"></canvas>
      <canvas id="gradient-canvas"></canvas>
      <canvas id="rct-effects-canvas"></canvas>
      <canvas id="rct-dots-canvas"></canvas>

      {% block header %}
        <header id="header" role="banner">
          {{ contao_section('header_left') }}
          {{ contao_section('header_right') }}
        </header>
      {% endblock %}

      <nav id="navbar" class="rct-navbar" role="navigation" aria-label="Hauptnavigation">
        <div class="rct-navbar-menu">
          {{ left|raw }}
        </div>
      </nav>

      <div id="mainContainer">

        {% block left_sidebar %}
        <aside id="left" aria-label="Hauptnavigation">
          {% block left_sidebar_close %}
          <button class="rct-sidebar-close-btn js-close-sidebar" aria-label="Menü schließen">
            <svg class="rct-icon-shove" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path class="arrow-1" d="M18 6L12 12L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              <path class="arrow-2" d="M12 6L6 12L12 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
          {% endblock %}
          <div class="inside sitenavigation">{{ left|raw }}</div>
          <div class="rct-sidebar-logo">{{ contao_section('left_logo') }}</div>
          <div class="rct-sidebar-footer">{{ contao_section('left_bottom') }}</div>
        </aside>
        {% endblock %}

        {# --------------------------------------------------------
           MAIN + FOOTER im Flow
        -------------------------------------------------------- #}
        <main id="main" role="main">
          <div class="rct-content-inner">
            {{ main|raw }}
          </div>

          {# Footer scrollt mit dem Content – 3-4 Boxen, klassisch #}
          <footer id="footer" role="contentinfo">
            {{ footer|raw }}
          </footer>
        </main>

        {% block right_sidebar %}
        <aside id="right" aria-label="Nebennavigation">
          <button id="rct-menu-right-toggle" class="rct-sidebar-close-btn right" title="Layer-Management">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none">
              <path class="arrow-1" d="M6 6L12 12L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              <path class="arrow-2" d="M12 6L18 12L12 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
          <div class="inside sitenavigation">{{ right|raw }}</div>
          <div class="rct-sidebar-logo">{{ contao_section('right_logo') }}</div>
          <div class="rct-sidebar-footer">{{ contao_section('right_bottom') }}</div>
        </aside>
        {% endblock %}

      </div>{# /#mainContainer #}

      {# --------------------------------------------------------
         BOTTOM – fix am Boden, immer sichtbar
      -------------------------------------------------------- #}
      {{ contao_section('bottom') }}

  </div>{# /#wrapper #}
  {% endblock %}{# wrapper #}
  
{# Das Overlay lebt außerhalb aller Layout-Container #}
  <div id="globalOverlay" class="rct-overlay" aria-hidden="true">
    <div class="rct-overlay-close-btn">&times;</div><div class="rct-overlay-content">{# Hier landet der Content via JS #}</div>
  </div>
  
{% endblock %}
