<div class="rct-theme-switcher" id="themeSwitcher"{% if vis is defined and vis and vis != 'both' %} data-rct-visibility="{{ vis }}"{% endif %}>
    <button class="theme-trigger">
        <span class="current-theme-dot"></span>
        <span class="current-theme-name">Standard</span>
        <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
    <div class="theme-dropdown">
        <ul class="theme-list">
            <li><button class="theme-opt-btn" data-set-theme="default"><span class="opt-dot default"></span><span class="opt-label">Light Blue</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="lime"><span class="opt-dot lime"></span><span class="opt-label">Lime Tech</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="purple"><span class="opt-dot purple"></span><span class="opt-label">Deep Purple</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="dark-cherry-bloom"><span class="opt-dot dark-cherry-bloom"></span><span class="opt-label">Baccara Rose</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="dark-cherry"><span class="opt-dot dark-cherry"></span><span class="opt-label">Dark Cherry</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="honey-moon"><span class="opt-dot honey-moon"></span><span class="opt-label">Honey Moon</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="candy-chaos"><span class="opt-dot candy-chaos"></span><span class="opt-label">Candy Chaos</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="sparta"><span class="opt-dot sparta"></span><span class="opt-label">Sparta</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="sparta2"><span class="opt-dot sparta2"></span><span class="opt-label">Sparta II</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="toxic-green"><span class="opt-dot toxic-green"></span><span class="opt-label">Toxic Green</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="claudy-sky"><span class="opt-dot claudy-sky"></span><span class="opt-label">Claudy Sky</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="glass-tank"><span class="opt-dot glass-tank"></span><span class="opt-label">Glass Tank</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="neon-grid"><span class="opt-dot neon-grid"></span><span class="opt-label">Neon Grid</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="magnetic-field"><span class="opt-dot magnetic-field"></span><span class="opt-label">Magnetic Field</span></button></li>
            <li><button class="theme-opt-btn" data-set-theme="dragon"><span class="opt-dot dragon"></span><span class="opt-label">Dragon Scale</span></button></li>
        </ul>
        <div class="theme-footer">
            <label class="save-toggle">
                <input type="checkbox" id="save-theme-pref" checked>
                <span>Dauerhaft merken</span>
            </label>
        </div>
    </div>
</div>
