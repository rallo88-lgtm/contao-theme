{% extends '@Contao/content_element/_base.html.twig' %}

{% if downloads %}
    {% set dl = downloads|first %}
    {% set ext = dl.file.extension(true)|upper %}
    {% set attributes = attrs()
        .addClass(['rct-download-card', "ext-#{dl.file.extension(true)}"])
        .mergeWith(attributes|default)
    %}
{% endif %}

{% block content %}
    {% if downloads %}
        {% set dl = downloads|first %}
        {% set ext = dl.file.extension(true)|upper %}
        {% set name = dl.file.extraMetadata.localized.default.title|default(dl.file.name) %}

        <a href="{{ dl.href }}" class="rct-download-link" title="{{ name }}"{% if dl.file.mimeType('') %} type="{{ dl.file.mimeType('') }}"{% endif %}>
            <span class="rct-download-icon">↓</span>
            <span class="rct-download-info">
                <span class="rct-download-name">{{ name }}</span>
                <span class="rct-download-meta">
                    <span class="rct-download-badge">{{ ext }}</span>
                </span>
            </span>
        </a>
    {% endif %}
{% endblock %}
