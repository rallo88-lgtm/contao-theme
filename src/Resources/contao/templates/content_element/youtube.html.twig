{% extends '@Contao/content_element/youtube.html.twig' %}

{#
  Klaro-Integration: iframe src → data-src, data-name="youtube"
  Klaro aktiviert den iframe sobald Consent für "youtube" erteilt wurde.
#}

{% add 'klaro_css' to head %}
  <link rel="stylesheet" href="/bundles/rct/css/klaro.min.css">
{% endadd %}
{% add 'klaro_config' to body %}
  <script src="/bundles/rct/js/klaro-config.js" defer></script>
{% endadd %}
{% add 'klaro_js' to body %}
  <script src="/bundles/rct/js/klaro.min.js" defer></script>
{% endadd %}

{% block iframe %}
    {% set iframe_attributes = attrs({width, height, allowfullscreen: true, referrerpolicy: 'strict-origin-when-cross-origin'})
        .set('data-name', 'youtube')
        .set('data-src', source.url)
        .setIfExists('title', title|default)
        .mergeWith(iframe_attributes|default)
    %}
    <iframe{{ iframe_attributes }}></iframe>
{% endblock %}
