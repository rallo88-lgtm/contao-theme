<div class="rct-people-box style-{{ boxStyle }}">
    {% if image %}
        <div class="rct-people-avatar"{% if avatarSize %} style="--rct-avatar-size:{{ avatarSize }}px"{% endif %}>
            <img src="{{ image }}" alt="{{ name }}" loading="lazy">
        </div>
    {% else %}
        <div class="rct-people-avatar rct-people-avatar--placeholder"{% if avatarSize %} style="--rct-avatar-size:{{ avatarSize }}px"{% endif %}>
            <span>{{ name|first|upper }}</span>
        </div>
    {% endif %}

    <div class="rct-people-body">
        {% if name %}
            <h3 class="rct-people-name">{{ name }}</h3>
        {% endif %}
        {% if role %}
            <p class="rct-people-role">{{ role }}</p>
        {% endif %}
        {% if bio %}
            <p class="rct-people-bio">{{ bio }}</p>
        {% endif %}
    </div>

    {% if email or phone or link %}
        <div class="rct-people-contacts">
            {% if email %}
                <a href="mailto:{{ email }}" class="rct-people-contact" title="{{ email }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <span>{{ email }}</span>
                </a>
            {% endif %}
            {% if phone %}
                <a href="tel:{{ phone|replace({' ': '', '/': '', '-': ''}) }}" class="rct-people-contact" title="{{ phone }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <span>{{ phone }}</span>
                </a>
            {% endif %}
            {% if link %}
                <a href="{{ link }}" class="rct-people-contact" target="_blank" rel="noopener" title="{{ linkText }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    <span>{{ linkText }}</span>
                </a>
            {% endif %}
        </div>
    {% endif %}
</div>
