{#
  RCT – rct_hero.html.twig
  Hero section element.
  layout: centered | split
#}
{% extends '@Contao/content_element/_base.html.twig' %}

{% block content %}
<section class="rct-hero layout-{{ layout }}{{ cssClass ? ' ' ~ cssClass }}"{% if htmlId %} id="{{ htmlId }}"{% endif %}{% if maxWidth %} style="max-width:{{ maxWidth }};margin-left:auto;margin-right:auto"{% endif %}>

  <div class="rct-hero-inner">

    <div class="rct-hero-text">

      {% if overline %}
        <div class="rct-hero-overline">{{ overline }}</div>
      {% endif %}

      <h1 class="rct-hero-headline"{% if hlColor or hlFont %} style="{% if hlColor %}color:{{ hlColor }};{% endif %}{% if hlFont %}font-family:'{{ hlFont }}';{% endif %}"{% endif %}>{{ headline|raw }}</h1>

      {% if body %}
        <div class="rct-hero-body"{% if hlColor %} style="color:{{ hlColor }}"{% endif %}>{{ body|raw }}</div>
      {% endif %}

      {% if btn1 or btn2 %}
        <div class="rct-hero-actions">
          {% if btn1 %}
            <a href="{{ btn1.url }}" class="rct-btn rct-btn--{{ btn1.style }}" target="{{ btn1.target }}"{% if btn1.target == '_blank' %} rel="noopener noreferrer"{% endif %}>
              {{ btn1.label }}
              <svg class="rct-hero-btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {% endif %}
          {% if btn2 %}
            <a href="{{ btn2.url }}" class="rct-btn rct-btn--{{ btn2.style }}" target="{{ btn2.target }}"{% if btn2.target == '_blank' %} rel="noopener noreferrer"{% endif %}>{{ btn2.label }}</a>
          {% endif %}
        </div>
      {% endif %}

      {% if stats %}
        <div class="rct-hero-stats">
          {% for stat in stats %}
            {% if not loop.first %}<div class="rct-hero-stat-sep" aria-hidden="true"></div>{% endif %}
            <div class="rct-hero-stat">
              <span class="rct-hero-stat-val">{{ stat.value }}</span>
              <span class="rct-hero-stat-label">{{ stat.label }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}

    </div>

    {% if layout == 'split' and images|length > 0 %}
      <div class="rct-hero-visual">
        <div class="rct-hero-img-wrap"{% if images|length > 1 %} data-hero-slides data-speed="{{ slideSpeed }}"{% endif %}>
          {% for img in images %}
            <img src="{{ img }}" alt="{{ loop.first ? imgAlt : '' }}" loading="{{ loop.first ? 'eager' : 'lazy' }}" decoding="async"{% if loop.first %} class="is-active"{% endif %}>
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>

  <div class="rct-hero-glow" aria-hidden="true"></div>

</section>

{% if images|length > 1 %}
<script>
(function() {
  document.querySelectorAll('[data-hero-slides]').forEach(function(wrap) {
    var imgs = wrap.querySelectorAll('img');
    if (imgs.length < 2) return;
    var speed = parseInt(wrap.dataset.speed || '5', 10) * 1000;
    var current = 0;
    setInterval(function() {
      imgs[current].classList.remove('is-active');
      current = (current + 1) % imgs.length;
      imgs[current].classList.add('is-active');
    }, speed);
  });
})();
</script>
{% endif %}
{% endblock %}
