{% extends '@Contao_ContaoCoreBundle/be_main.html.twig' %}

{% block headline %}{{ headline }}{% endblock %}

{% block main %}
<style>
.rct-config-wrap { max-width: 900px; }
.rct-config-outer { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
.rct-config-section { background: #fff; border: 1px solid #ddd; border-radius: 4px; }
.rct-config-section h2 { font-size: 13px; font-weight: 700; color: #555; padding: 12px 16px; margin: 0; border-bottom: 1px solid #eee; background: #f8f8f8; border-radius: 4px 4px 0 0; }
.rct-config-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; padding: 16px; }
.rct-config-field label { display: block; font-size: 11px; font-weight: 600; color: #666; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
.rct-config-field input[type="text"], .rct-config-field select { width: 100%; padding: 7px 10px; border: 1px solid #ccc; border-radius: 3px; font-size: 13px; }
.rct-color-field { display: flex; align-items: center; gap: 8px; }
.rct-color-swatch { width: 42px; height: 38px; flex-shrink: 0; border: 1px solid #ccc; border-radius: 3px; cursor: pointer; padding: 2px; background: none; }
.rct-hex-input { flex: 1; padding: 7px 10px; border: 1px solid #ccc; border-radius: 3px; font-size: 13px; font-family: monospace; letter-spacing: 0.04em; }
.rct-hex-input:focus { outline: none; border-color: #999; }
.rct-hex-input.is-invalid { border-color: #e04b4b; background: #fff5f5; }
.rct-config-field select { background: #fff; }
.rct-font-preview { margin-top: 6px; font-size: 12px; color: #999; }
.rct-grad-preview { height: 36px; border-radius: 3px; margin-top: 8px; border: 1px solid #eee; transition: background 0.3s; }
.rct-save-bar { background: #f5f5f5; border-top: 1px solid #ddd; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
.rct-saved-msg { color: #5a8a2e; font-weight: 600; font-size: 13px; }
.rct-reset-btn { font-size: 12px; color: #999; background: none; border: none; cursor: pointer; text-decoration: underline; }
.rct-reset-btn:hover { color: #666; }
</style>

<div class="tl_listing_container rct-config-wrap">

  {% if saved %}
  <p class="tl_confirm">Einstellungen wurden gespeichert.</p>
  {% endif %}

  <form method="post" id="rct-config-form">
    <input type="hidden" name="REQUEST_TOKEN" value="{{ request_token }}">

  <div class="rct-config-outer">

    {# ── Schriften ─────────────────────────────────────────── #}
    <div class="rct-config-section">
      <h2>Schriften</h2>
      <div class="rct-config-grid">

        <div class="rct-config-field">
          <label for="rct_font_body">Hauptschrift (Body &amp; Headlines)</label>
          <select name="rct_font_body" id="rct_font_body">
            {% for family, files in fonts %}
              <option value="{{ family }}" {{ config.rct_font_body == family ? 'selected' }}>{{ family }}</option>
            {% endfor %}
          </select>
          <div class="rct-font-preview" id="preview-font-body" style="font-family: '{{ config.rct_font_body }}', sans-serif;">
            The quick brown fox — 0123456789
          </div>
        </div>

        <div class="rct-config-field">
          <label for="rct_font_mono">Monospace-Schrift</label>
          <select name="rct_font_mono" id="rct_font_mono">
            {% for family, files in fonts %}
              <option value="{{ family }}" {{ config.rct_font_mono == family ? 'selected' }}>{{ family }}</option>
            {% endfor %}
          </select>
          <div class="rct-font-preview" id="preview-font-mono" style="font-family: '{{ config.rct_font_mono }}', monospace;">
            const rct = () =&gt; &lt;/&gt;;
          </div>
        </div>

      </div>
    </div>

    {# ── Farben ─────────────────────────────────────────────── #}
    <div class="rct-config-section">
      <h2>Farben (Standard-Theme)</h2>
      <div class="rct-config-grid">

        <div class="rct-config-field">
          <label for="rct_color_accent">Akzentfarbe (--rct-accent)</label>
          <div class="rct-color-field">
            <input type="color" name="rct_color_accent" id="rct_color_accent" class="rct-color-swatch" value="{{ config.rct_color_accent }}">
            <input type="text" class="rct-hex-input" value="{{ config.rct_color_accent }}" maxlength="7" spellcheck="false" placeholder="#000000" data-for="rct_color_accent">
          </div>
        </div>

        <div class="rct-config-field">
          <label for="rct_color_primary">Primärfarbe (--rct-primary)</label>
          <div class="rct-color-field">
            <input type="color" name="rct_color_primary" id="rct_color_primary" class="rct-color-swatch" value="{{ config.rct_color_primary }}">
            <input type="text" class="rct-hex-input" value="{{ config.rct_color_primary }}" maxlength="7" spellcheck="false" placeholder="#000000" data-for="rct_color_primary">
          </div>
        </div>

        <div class="rct-config-field">
          <label for="rct_color_primary_light">Primär Hell (--rct-primary-light)</label>
          <div class="rct-color-field">
            <input type="color" name="rct_color_primary_light" id="rct_color_primary_light" class="rct-color-swatch" value="{{ config.rct_color_primary_light }}">
            <input type="text" class="rct-hex-input" value="{{ config.rct_color_primary_light }}" maxlength="7" spellcheck="false" placeholder="#000000" data-for="rct_color_primary_light">
          </div>
        </div>

      </div>
    </div>

    {# ── Canvas-Gradient ────────────────────────────────────── #}
    <div class="rct-config-section">
      <h2>Canvas-Gradient (Standard-Theme)</h2>
      <div class="rct-config-grid">

        {% for i in 1..4 %}
        <div class="rct-config-field">
          <label for="rct_grad{{ i }}">Gradient {{ i }}</label>
          <div class="rct-color-field">
            <input type="color" name="rct_grad{{ i }}" id="rct_grad{{ i }}" class="rct-color-swatch rct-grad-input" value="{{ attribute(config, 'rct_grad' ~ i) }}">
            <input type="text" class="rct-hex-input" value="{{ attribute(config, 'rct_grad' ~ i) }}" maxlength="7" spellcheck="false" placeholder="#000000" data-for="rct_grad{{ i }}">
          </div>
        </div>
        {% endfor %}

      </div>
      <div style="padding: 0 16px 16px;">
        <div class="rct-grad-preview" id="grad-preview"></div>
      </div>
    </div>

    {# ── Layout ─────────────────────────────────────────────── #}
    <div class="rct-config-section">
      <h2>Layout</h2>
      <div class="rct-config-grid">

        <div class="rct-config-field">
          <label for="rct_sidebar_width">Sidebar-Breite</label>
          <input type="text" name="rct_sidebar_width" id="rct_sidebar_width" value="{{ config.rct_sidebar_width }}" placeholder="260px">
        </div>

        <div class="rct-config-field">
          <label for="rct_header_height">Header-Höhe</label>
          <input type="text" name="rct_header_height" id="rct_header_height" value="{{ config.rct_header_height }}" placeholder="64px">
        </div>

        <div class="rct-config-field">
          <label for="rct_radius">Border-Radius</label>
          <input type="text" name="rct_radius" id="rct_radius" value="{{ config.rct_radius }}" placeholder="0.125rem">
        </div>

      </div>
    </div>

  </div>{# /.rct-config-outer #}

  {# ── Verfügbare Themes ─────────────────────────────────── #}
  {% set activeThemes = config.rct_allowed_themes ? config.rct_allowed_themes|split(',') : all_themes|keys %}
  <div class="rct-config-section" style="margin-bottom: 24px;">
    <h2>Verfügbare Themes</h2>
    <div style="padding: 12px 16px 4px;">
      <p style="font-size: 12px; color: #888; margin: 0 0 12px;">Legt fest welche Themes im FE-Theme-Switcher auswählbar sind. Ist nur ein Theme aktiv, wird es als festes Theme erzwungen — kein Switcher nötig.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px 16px; padding-bottom: 12px;">
        {% for key, label in all_themes %}
        <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; padding: 4px 0;">
          <input type="checkbox" name="rct_allowed_themes[]" value="{{ key }}"
            {{ key in activeThemes ? 'checked' }}>
          {{ label }}
        </label>
        {% endfor %}
      </div>
    </div>
  </div>

    <div class="rct-save-bar">
      <button type="submit" class="tl_submit">Einstellungen speichern</button>
      <button type="button" class="rct-reset-btn" id="rct-reset-btn">Auf Standardwerte zurücksetzen</button>
    </div>

  </form>

</div>

<script>
(function() {
  // Color swatch ↔ hex text sync
  document.querySelectorAll('.rct-hex-input').forEach(function(hexInput) {
    var colorInput = document.getElementById(hexInput.dataset.for);
    if (!colorInput) return;

    // Swatch → Text
    colorInput.addEventListener('input', function() {
      hexInput.value = this.value.toUpperCase();
      hexInput.classList.remove('is-invalid');
    });

    // Text → Swatch
    hexInput.addEventListener('input', function() {
      var val = this.value.trim();
      var normalized = val.startsWith('#') ? val : '#' + val;
      if (/^#[0-9a-fA-F]{6}$/.test(normalized)) {
        colorInput.value = normalized;
        colorInput.dispatchEvent(new Event('input'));
        this.classList.remove('is-invalid');
      } else {
        this.classList.toggle('is-invalid', val.length > 0);
      }
    });

    // Uppercase on blur, reset invalid if empty
    hexInput.addEventListener('blur', function() {
      if (this.value === '' || this.value === '#') {
        this.value = colorInput.value.toUpperCase();
        this.classList.remove('is-invalid');
      } else {
        this.value = this.value.toUpperCase();
      }
    });

    hexInput.value = hexInput.value.toUpperCase();
  });

  // Live gradient preview
  function updateGradPreview() {
    var colors = Array.from(document.querySelectorAll('.rct-grad-input')).map(el => el.value);
    document.getElementById('grad-preview').style.background =
      'linear-gradient(135deg, ' + colors.join(', ') + ')';
  }
  document.querySelectorAll('.rct-grad-input').forEach(function(el) {
    el.addEventListener('input', updateGradPreview);
  });
  updateGradPreview();

  // Font live preview
  document.getElementById('rct_font_body').addEventListener('change', function() {
    document.getElementById('preview-font-body').style.fontFamily = "'" + this.value + "', sans-serif";
  });
  document.getElementById('rct_font_mono').addEventListener('change', function() {
    document.getElementById('preview-font-mono').style.fontFamily = "'" + this.value + "', monospace";
  });

  // Reset — aktualisiert auch Hex-Inputs
  var defaults = {{ defaults|json_encode|raw }};
  document.getElementById('rct-reset-btn').addEventListener('click', function() {
    if (!confirm('Alle Werte auf Standard zurücksetzen?')) return;
    Object.keys(defaults).forEach(function(key) {
      var el = document.querySelector('[name="' + key + '"]');
      if (!el) return;
      el.value = defaults[key];
      var hex = document.querySelector('[data-for="' + key + '"]');
      if (hex) { hex.value = defaults[key].toUpperCase(); hex.classList.remove('is-invalid'); }
    });
    updateGradPreview();
  });
})();
</script>
{% endblock %}
