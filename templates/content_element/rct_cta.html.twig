{#
  RCT – rct_cta.html.twig
  Call-to-Action element.
  layout: centered | banner | card
#}
{% extends '@Contao/content_element/_base.html.twig' %}

{% block content %}
<div class="rct-cta layout-{{ layout }} style-{{ ctaStyle }}{{ cssClass ? ' ' ~ cssClass }}" style="--cta-color: {{ colorCss }}; --cta-btn-fg: {{ btnFg }};"{% if htmlId %} id="{{ htmlId }}"{% endif %}>

  {% if layout == 'banner' %}

    {# ── Banner: icon+text left, buttons right ── #}
    <div class="rct-cta-body">
      {% if icon %}<span class="rct-cta-icon" aria-hidden="true">{{ icon }}</span>{% endif %}
      <div class="rct-cta-text-wrap">
        {% if ctaHeadline %}<p class="rct-cta-headline">{{ ctaHeadline }}</p>{% endif %}
        {% if ctaText %}<p class="rct-cta-text">{{ ctaText|raw }}</p>{% endif %}
      </div>
    </div>
    {% if btn1 or btn2 %}
      <div class="rct-cta-actions">
        {% if btn1 %}<a href="{{ btn1.url }}" class="rct-btn rct-btn--{{ btn1.style }}" target="{{ btn1.target }}" {% if btn1.target == '_blank' %}rel="noopener noreferrer"{% endif %}>{{ btn1.label }}</a>{% endif %}
        {% if btn2 %}<a href="{{ btn2.url }}" class="rct-btn rct-btn--{{ btn2.style }}" target="{{ btn2.target }}" {% if btn2.target == '_blank' %}rel="noopener noreferrer"{% endif %}>{{ btn2.label }}</a>{% endif %}
      </div>
    {% endif %}

  {% else %}

    {# ── Centered & Card ── #}
    {% if icon %}<div class="rct-cta-icon" aria-hidden="true">{{ icon }}</div>{% endif %}
    {% if ctaHeadline %}<h2 class="rct-cta-headline">{{ ctaHeadline }}</h2>{% endif %}
    {% if ctaText %}<p class="rct-cta-text">{{ ctaText|raw }}</p>{% endif %}
    {% if btn1 or btn2 %}
      <div class="rct-cta-actions">
        {% if btn1 %}<a href="{{ btn1.url }}" class="rct-btn rct-btn--{{ btn1.style }}" target="{{ btn1.target }}" {% if btn1.target == '_blank' %}rel="noopener noreferrer"{% endif %}>{{ btn1.label }}</a>{% endif %}
        {% if btn2 %}<a href="{{ btn2.url }}" class="rct-btn rct-btn--{{ btn2.style }}" target="{{ btn2.target }}" {% if btn2.target == '_blank' %}rel="noopener noreferrer"{% endif %}>{{ btn2.label }}</a>{% endif %}
      </div>
    {% endif %}

  {% endif %}

  <div class="rct-cta-glow" aria-hidden="true"></div>
</div>
{% endblock %}
